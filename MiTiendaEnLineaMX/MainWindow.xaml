<Window x:Class="MiTiendaEnLineaMX.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="MiTiendaEnLineaMX"
        Height="760"
        Width="1280"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Grid.Row="0" Background="#1F2937" Padding="12">
            <DockPanel LastChildFill="False">
                <TextBlock Text="MiTiendaEnLineaMX"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"/>

                <Button x:Name="btnToggleConfig"
                        Content="⚙ Configuración"
                        Width="150"
                        Height="32"
                        DockPanel.Dock="Right"
                        Click="btnToggleConfig_Click"/>
            </DockPanel>
        </Border>

        <!-- CONTENIDO -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="colConfig" Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- WEB -->
            <wv2:WebView2 x:Name="webView"
                          Grid.Column="0"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"/>

            <!-- PANEL LATERAL -->
            <Border x:Name="configPanel"
                    Grid.Column="1"
                    Background="#F5F5F5"
                    Padding="16"
                    Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,14">
                            <TextBlock Text="Configuración de impresión"
                                       FontWeight="Bold"
                                       FontSize="18"
                                       VerticalAlignment="Center"
                                       DockPanel.Dock="Left"/>

                            <Button Content="✕"
                                    Width="30"
                                    Height="30"
                                    DockPanel.Dock="Right"
                                    Click="btnToggleConfig_Click"/>
                        </DockPanel>

                        <!-- MODO -->
                        <TextBlock Text="Modo de impresión" FontWeight="Bold"/>
                        <ComboBox x:Name="cmbMode"
                                  Margin="0,6,0,10"
                                  SelectionChanged="cmbMode_SelectionChanged">
                            <ComboBoxItem Content="TCP/IP" IsSelected="True"/>
                            <ComboBoxItem Content="USB"/>
                        </ComboBox>

                        <!-- TCP -->
                        <StackPanel x:Name="panelTcp">
                            <TextBlock Text="IP de la impresora" FontWeight="Bold"/>
                            <TextBox x:Name="txtIP" Margin="0,6,0,10"/>

                            <TextBlock Text="Puerto" FontWeight="Bold"/>
                            <TextBox x:Name="txtPort" Text="9100" Margin="0,6,0,10"/>
                        </StackPanel>

                        <!-- USB -->
                        <StackPanel x:Name="panelUsb" Visibility="Collapsed">
                            <TextBlock Text="Nombre de impresora USB" FontWeight="Bold"/>
                            <TextBox x:Name="txtPrinterName" Margin="0,6,0,10"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Content="Detectar impresoras"
                                        Width="150"
                                        Height="34"
                                        Margin="0,0,10,0"
                                        Click="LoadPrinters_Click"/>

                                <Button Content="Usar seleccionada"
                                        Width="150"
                                        Height="34"
                                        Click="UseSelectedPrinter_Click"/>
                            </StackPanel>

                            <TextBlock Text="Impresoras instaladas" FontWeight="Bold"/>
                            <ComboBox x:Name="cmbPrinters"
                                      Margin="0,6,0,10"
                                      SelectionChanged="cmbPrinters_SelectionChanged"/>
                        </StackPanel>

                        <TextBlock Text="Tamaño de papel" FontWeight="Bold"/>
                        <ComboBox x:Name="cmbPaper" Margin="0,6,0,10">
                            <ComboBoxItem Content="80 mm" IsSelected="True"/>
                            <ComboBoxItem Content="58 mm"/>
                        </ComboBox>

                        <StackPanel Orientation="Horizontal" Margin="0,6,0,12">
                            <CheckBox x:Name="chkCut"
                                      Content="Cortar al final"
                                      IsChecked="True"
                                      Margin="0,0,20,0"/>
                            <CheckBox x:Name="chkDrawer"
                                      Content="Abrir cajón"
                                      IsChecked="True"/>
                        </StackPanel>

                        <TextBlock Text="Logo en Base64" FontWeight="Bold"/>
                        <TextBox x:Name="txtLogoBase64"
                                 Margin="0,6,0,12"
                                 Height="110"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"/>

                        <TextBlock Text="Accesos" FontWeight="Bold" Margin="0,4,0,8"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Tienda"
                                    Width="150"
                                    Height="34"
                                    Margin="0,0,10,0"
                                    Click="OpenStore_Click"/>

                            <Button Content="Punto de Venta"
                                    Width="150"
                                    Height="34"
                                    Click="OpenPos_Click"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,10">
                            <Button Content="Guardar configuración"
                                    Width="150"
                                    Height="34"
                                    Margin="0,0,10,0"
                                    Click="SaveConfig_Click"/>

                            <Button Content="Cargar configuración"
                                    Width="150"
                                    Height="34"
                                    Click="LoadConfig_Click"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,10">
                            <Button Content="Imprimir prueba"
                                    Width="150"
                                    Height="34"
                                    Margin="0,0,10,0"
                                    Click="Print_Click"/>

                            <Button Content="Probar TCP"
                                    Width="150"
                                    Height="34"
                                    Click="TestTcp_Click"/>
                        </StackPanel>

                        <TextBlock Text="Log bridge" FontWeight="Bold" Margin="0,12,0,8"/>
                        <TextBox x:Name="txtLog"
                                 Height="220"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"
                                 IsReadOnly="True"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
